{
    "name": "ajtarragona/mailrelay-client",
    "description": "Client Laravel de la API Rest de MailRelay",
    "keywords": [
        "laravel12",
        "laravel"
    ],
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Txomin Medrano Martorell",
            "email": "tmedrano@tarragona.cat"
        }
    ],
    "minimum-stability": "dev",
    "require": {
        "php": "^8.2",
        "laravel/framework": "^12.0"
    },
    "autoload": {
        "psr-4": {
            "Ajtarragona\\MailRelay\\": "./src"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Ajtarragona\\MailRelay\\MailRelayServiceProvider"
            ],
            "aliases": {
                "MailRelay": "Ajtarragona\\MailRelay\\Facades\\MailRelay"
            }
        }
    }
}